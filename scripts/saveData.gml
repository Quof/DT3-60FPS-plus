/*
Save script.
This will save the game data. (ini)
*/
playSound(global.snd_SaveGame,0,1,1)
bSaving=1

var tNewMessage,sectionWrite,tempVar,saveProgress;
tNewMessage=instance_create(view_xview[0]+170,view_yview[0]+100,oMessageSign)
tNewMessage.message="Saving, please wait..."
tNewMessage.fadingTime=45
tNewMessage.signSize=0
tNewMessage.depth=-101
saveProgress=0

screen_redraw()

ini_open(global.paraString[0])
ini_write_string("ABOUT","NOTICE","Do not edit this file, doing so will corrupt saved data and cause the game to run incorrectly. Also your save data may be deleted.")

sectionWrite="ALPHA"
var tempVar;
ini_write_real(sectionWrite,"gamebeat",0)

ini_write_real(sectionWrite,"101",global.playTimeHour)
ini_write_real(sectionWrite,"102",global.playTimeMinute)
ini_write_real(sectionWrite,"103",global.playTimeSecond)
ini_write_real(sectionWrite,"104",global.pMaxLife)
ini_write_real(sectionWrite,"105",global.pLife)
ini_write_real(sectionWrite,"106",global.pAP)
ini_write_real(sectionWrite,"107",global.pAPLevel)
ini_write_real(sectionWrite,"108",global.pAPExp)
ini_write_real(sectionWrite,"109",global.pAPNext)
ini_write_real(sectionWrite,"110",global.pMoney)
ini_write_real(sectionWrite,"111",global.pMoneyMax)
ini_write_real(sectionWrite,"113",global.pKeys)
ini_write_real(sectionWrite,"114",global.pHeartPieces)
ini_write_real(sectionWrite,"115",global.activeCharacter)
ini_write_real(sectionWrite,"116",global.canCharSwap)
ini_write_real(sectionWrite,"116dj",global.canDoubleJump)
for (i=0;i<2;i+=1)
  ini_write_real(sectionWrite,string("116s") +string(i),global.charScan[i])
for (i=0;i<2;i+=1)
  ini_write_real(sectionWrite,string("117a") +string(i),global.activeAbility[i])
for (i=0;i<4;i+=1)
  ini_write_real(sectionWrite,string("118a") +string(i),global.hasShoes[i])
for(i=0;i<7;i+=1)
  ini_write_real(sectionWrite,string("119a") +string(i),global.hasAbilToken[i])

ini_write_real(sectionWrite,"120",global.location)
if global.location=49
{
  ini_write_real(sectionWrite,"130",global.metCheckpoint[0])
  ini_write_real(sectionWrite,"121",global.metCheckpoint[1])
  ini_write_real(sectionWrite,"122",global.metCheckpoint[2])
  ini_write_real(sectionWrite,"130rm",room)
}
else
{
  ini_write_real(sectionWrite,"130",room)
  ini_write_real(sectionWrite,"121",global.newMapX)
  ini_write_real(sectionWrite,"122",global.newMapY)
}
ini_write_real(sectionWrite,"123",global.gameProgress)
