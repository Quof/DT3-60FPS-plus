with oMessageSign {instance_destroy()}
var tNewMessage;
tNewMessage=instance_create(view_xview[0]+170,view_yview[0]+100,oMessageSign)
if room=rTitle {tNewMessage.message="Saved New File!!"}
else {tNewMessage.message="Save Successful!!"}
