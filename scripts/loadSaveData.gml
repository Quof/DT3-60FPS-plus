/*
This script is used to load in saved data (ini)
argument0:  0: Load from Title Screen
            1: Load from Game Over Screen or from Pause Menu
*/
ini_open(global.paraString[0])
var sectionRead,tempVar;

sectionRead="ALPHA"
var tempVar;
checkIfCheating=ini_read_real(sectionRead,"gamebeat",0)

